# =============================================================================
# AI SaaS Framework — Staging Environment Sample (T-12.01)
# Spec: docs/SDS.md §6.6 | docs/SECURITY_HARDENING.md
# =============================================================================
# Usage:
#   Copy to `.env.staging` (never commit `.env.staging`)
#   Fill every CHANGE_ME / empty secret before `docker compose … up`
# =============================================================================

APP_ENV=staging

# Compose-internal DB/Redis (host ports are NOT published in staging compose)
POSTGRES_USER=aisaas
POSTGRES_PASSWORD=CHANGE_ME_staging_db_password
POSTGRES_DB=ai_saas

# Sync driver URL used inside containers (compose overrides host to `postgres`)
DATABASE_URL=postgresql+psycopg://aisaas:CHANGE_ME_staging_db_password@postgres:5432/ai_saas
REDIS_URL=redis://redis:6379/0

# Strong random secret (≥32 bytes). Placeholder only — replace before boot.
JWT_SECRET=CHANGE_ME_staging_jwt_secret_use_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# Browser origin for staging web (default published port 13000)
CORS_ORIGINS=http://localhost:13000

OPENAI_API_KEY=
GEMINI_API_KEY=
AI_PRIMARY_PROVIDER=openai
AI_FALLBACK_PROVIDER=gemini
AI_FALLBACK_ENABLED=false
AI_RATE_LIMIT_MAX=30
AI_RATE_LIMIT_WINDOW_SECONDS=60

STORAGE_PATH=/data/storage

OCR_LANG=korean+en
OCR_MAX_PAGES=20
OCR_MAX_ATTEMPTS=3
OCR_RETRY_BASE_SECONDS=2
OCR_RECONCILE_ENABLED=true
OCR_STALE_QUEUED_SECONDS=180
OCR_STALE_RUNNING_SECONDS=1200
UPLOAD_MAX_BYTES=10485760

STATS_MATERIALIZE_ENABLED=true
STATS_SUMMARY_CACHE_SECONDS=300

# Host-published ports (compose defaults)
STAGING_API_PORT=18000
STAGING_WEB_PORT=13000
NEXT_PUBLIC_API_BASE_URL=http://localhost:18000

# Admin seed — change before shared staging
SEED_ADMIN_EMAIL=admin@staging.example.com
SEED_ADMIN_PASSWORD=CHANGE_ME_StagingAdmin1!
SEED_ADMIN_NAME=StagingAdmin
