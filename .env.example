# =============================================================================
# AI SaaS Framework — Environment Contract
# Spec: docs/SDS.md §6.6 | Task: docs/TASKS.md T-0.02
# =============================================================================
# Usage:
#   1. Copy this file to `.env` (never commit `.env`)
#   2. Replace placeholder values for local/staging/production
#   3. Leave empty keys empty until the owning feature is configured
#
# Rules:
#   - This file must contain NO real secrets (API keys, production JWT, etc.)
#   - Sample values below are for local development only
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# Consumed by: api, worker, web
# Allowed values: local | staging | production
# -----------------------------------------------------------------------------
APP_ENV=local

# -----------------------------------------------------------------------------
# PostgreSQL (System of Record)
# Consumed by: api, worker
# Format: SQLAlchemy DSN (async driver example: postgresql+asyncpg://...)
#
# Host tools (alembic from Windows/macOS): use localhost + published port.
# docker-compose.yml maps postgres as host 5433 -> container 5432.
# Inside Compose network, api/worker override to host name `postgres:5432`.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://aisaas:aisaas@localhost:5433/ai_saas

# -----------------------------------------------------------------------------
# Redis (cache, rate limit, refresh denylist, job queue — not SoR)
# Consumed by: api, worker
# Format: redis://host:port/db
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# JWT authentication
# Consumed by: api
# JWT_SECRET: strong random secret in non-local environments (placeholder only here)
# JWT_ALGORITHM: e.g. HS256
# ACCESS_TOKEN_TTL_MINUTES: short-lived access token lifetime
# REFRESH_TOKEN_TTL_DAYS: refresh token lifetime
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-local-placeholder-not-a-real-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=14

# -----------------------------------------------------------------------------
# CORS allowlist
# Consumed by: api
# Comma-separated origins. Do not use * when credentials=true (SDS ADR-030).
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# AI providers (OpenAI / Gemini)
# Consumed by: api, worker
# Leave API keys empty in this example; set them only in private `.env`
# AI_PRIMARY_PROVIDER: openai | gemini
# AI_FALLBACK_PROVIDER: optional secondary provider
# AI_FALLBACK_ENABLED: true | false
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
GEMINI_API_KEY=
AI_PRIMARY_PROVIDER=openai
AI_FALLBACK_PROVIDER=gemini
AI_FALLBACK_ENABLED=false
# Per-user AI chat/vision rate limit (T-5.07); Redis key aisaas:rl:ai:{user_id}
AI_RATE_LIMIT_MAX=60
AI_RATE_LIMIT_WINDOW_SECONDS=60

# -----------------------------------------------------------------------------
# File storage (local volume root; StoragePort)
# Consumed by: api, worker
# Compose(api/worker): /data/storage (volume mount)
# Host hybrid (uvicorn/arq on Windows/macOS): use a local path, e.g. ./data/storage
# -----------------------------------------------------------------------------
STORAGE_PATH=/data/storage

# -----------------------------------------------------------------------------
# OCR / upload limits
# OCR_LANG: consumed by worker (default korean+en per SDS ADR-011)
# OCR_MAX_PAGES: consumed by api, worker
# OCR_MAX_ATTEMPTS / OCR_RETRY_BASE_SECONDS: worker retry (T-4.06)
# OCR_RECONCILE_*: stale queued/running recovery cron (T-4.09)
# UPLOAD_MAX_BYTES: consumed by api (bytes)
# -----------------------------------------------------------------------------
OCR_LANG=korean+en
OCR_MAX_PAGES=20
OCR_MAX_ATTEMPTS=3
OCR_RETRY_BASE_SECONDS=2
OCR_RECONCILE_ENABLED=true
OCR_STALE_QUEUED_SECONDS=180
OCR_STALE_RUNNING_SECONDS=1200
UPLOAD_MAX_BYTES=10485760

# -----------------------------------------------------------------------------
# Statistics (T-7.02 materialize cron / T-7.05 summary cache)
# STATS_MATERIALIZE_ENABLED: ARQ cron rebuilds stat_daily every 10 minutes
# STATS_SUMMARY_CACHE_SECONDS: Redis TTL for /stats/summary (0 disables reuse quickly)
# -----------------------------------------------------------------------------
STATS_MATERIALIZE_ENABLED=true
STATS_SUMMARY_CACHE_SECONDS=300

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# Consumed by: web
# Public API origin used by the browser client
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Admin seed (T-1.07)
# Consumed by: scripts/seed.sh → python -m app.scripts.seed_admin
# Local placeholders only — change before any shared/staging environment.
# -----------------------------------------------------------------------------
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMeAdmin1!
SEED_ADMIN_NAME=Admin
